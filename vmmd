class Config:
    def __init__(self, pathname=None, defaults=None):
        if defaults:
            self._config = defaults
        else:
            self._config = {}
        if pathname:
            self.load(pathname)

    def load(self, pathname):
        try:
            f = open(pathname, 'r')
        except IOError as e:
            if e.errno == errno.ENOENT:
                return
            raise
        for line in f:
            i = line.find('#')
            if i != -1:
                line = line[:i]
            line = line.strip()
            if not line:
                continue
            append = False
            if line.find('+=') != -1:
                fields = line.split('+=', 1)
                append = True
            elif line.find('=') != -1:
                fields = line.split('=', 1)
            else:
                fields = [line, 'true']

            k = fields[0].strip()
            v = autotype(fields[1].strip())
            if append:
                if k in self._config:
                    if is_int(self._config[k]):
                        self._config[k] += v
                    else:
                        self._config[k] += " %s" % (v)
                else:
                    self._config[k] = v
            else:
                self._config[k] = v

    def __contains__(self, k):
        return k in self._config

    def __getitem__(self, k):
        if not k in self._config:
            raise KeyError(k)
        return self._config[k]

    def get(self, k, default=None):
        if not k in self._config:
            return default
        return self._config[k]

