def vm_reaper():
    while True:
        try:
            for oid, vm in vm_db.items():
                if vm.running():
                    proc_dir = "/proc/%d" % (vm.pid())
                    if not os.path.isdir(proc_dir):
                        vm.notify_stopped()
        except BaseException as e:
            loge("Exception in vm_reaper thread: %s" % (e))
        time.sleep(1)

